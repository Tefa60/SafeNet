@* SafeNet.Web/Views/Shared/Error.cshtml *@
@* REEMPLAZAR el archivo existente con este contenido *@
@{
    ViewData["Title"] = "Error inesperado";
    Layout = "_Layout";
}

<style>
    .error-page {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .error-code {
        font-size: 8rem;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg, #C00000 0%, #e74c3c 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .pulse-anim {
        animation: pulsar 2s ease-in-out infinite;
    }
    @@keyframes pulsar {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.7; transform: scale(0.95); }
    }
</style>

<div class="error-page">
    <div class="text-center px-4">

        <i class="bi bi-exclamation-triangle-fill pulse-anim text-danger" style="font-size: 5rem;"></i>

        <div class="error-code mt-2">500</div>

        <h2 class="fw-bold mt-2 mb-2">Algo salió mal</h2>
        <p class="text-muted mb-4" style="max-width: 420px; margin: 0 auto;">
            Ocurrió un error inesperado en el servidor.
            El equipo ha sido notificado. Intenta de nuevo en unos momentos.
        </p>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Home" asp-action="Index"
               class="btn btn-danger rounded-3 px-4">
                <i class="bi bi-house me-1"></i> Ir al inicio
            </a>
            <button onclick="history.back()"
                    class="btn btn-outline-secondary rounded-3 px-4">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </button>
        </div>

        <p class="text-muted small mt-5">
            <i class="bi bi-clock me-1"></i>
            Si el problema persiste, contacta a
            <a href="mailto:admin@safenet.com" class="text-decoration-none">admin@safenet.com</a>
        </p>

    </div>
</div>
