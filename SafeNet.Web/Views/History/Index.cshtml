@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@* SafeNet.Web/Views/History/Index.cshtml *@
@* REEMPLAZAR el archivo existente con este contenido completo *@
@model SafeNet.Web.Models.ViewModels.HistoryViewModel
@{
    ViewData["Title"] = "Mi Historial";
}

<div class="container py-5">

    @* ‚îÄ‚îÄ Encabezado ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold mb-0">Mi Historial</h1>
            <p class="text-muted small mb-0">
                @Model.TotalAnalyses an√°lisis realizados
                @if (Model.HasActiveFilters)
                {
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill ms-1">
                        @Model.TotalFiltered resultado@(Model.TotalFiltered != 1 ? "s" : "") filtrado@(Model.TotalFiltered != 1 ? "s" : "")
                    </span>
                }
            </p>
        </div>
        <a asp-action="ExportCsv"
           asp-route-filterVerdict="@Model.FilterVerdict"
           asp-route-filterType="@Model.FilterType"
           asp-route-filterDate="@Model.FilterDate"
           asp-route-search="@Model.Search"
           class="btn btn-outline-success rounded-3">
            <i class="bi bi-download me-1"></i> Exportar CSV
        </a>
    </div>

    @* ‚îÄ‚îÄ Tarjetas de estad√≠sticas ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="fw-bold fs-2">@Model.TotalAnalyses</div>
                <div class="text-muted small">Total</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="fw-bold fs-2 text-danger">@Model.TotalScams</div>
                <div class="text-muted small">Estafas</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="fw-bold fs-2 text-warning">@Model.TotalSuspect</div>
                <div class="text-muted small">Sospechosas</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center p-3">
                <div class="fw-bold fs-2 text-success">@Model.TotalSafe</div>
                <div class="text-muted small">Seguras</div>
            </div>
        </div>
    </div>

    @* ‚îÄ‚îÄ Buscador + Filtros ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ *@
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" asp-action="Index" asp-controller="History">

                @* Barra de b√∫squeda *@
                <div class="input-group mb-3">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-control border-start-0 border-end-0"
                           placeholder="Buscar en contenido, se√±ales o recomendaci√≥n..."
                           autocomplete="off" />
                    @if (!string.IsNullOrEmpty(Model.Search))
                    {
                        <a asp-action="Index"
                           asp-route-filterVerdict="@Model.FilterVerdict"
                           asp-route-filterType="@Model.FilterType"
                           asp-route-filterDate="@Model.FilterDate"
                           class="btn btn-outline-secondary border-start-0">
                            <i class="bi bi-x"></i>
                        </a>
                    }
                    <button type="submit" class="btn btn-primary rounded-end-3">
                        Buscar
                    </button>
                </div>

                @* Filtros *@
                <div class="row g-2">
                    <div class="col-md-4">
                        <select name="filterVerdict" class="form-select form-select-sm rounded-3"
                                onchange="this.form.submit()">
                            <option value="">Todos los veredictos</option>
                            <option value="ESTAFA"@(Model.FilterVerdict == "ESTAFA" ? " selected" : "")>Estafa</option>
                            <option value="SOSPECHOSA"@(Model.FilterVerdict == "SOSPECHOSA" ? " selected" : "")>Sospechosa</option>
                            <option value="SEGURA"@(Model.FilterVerdict == "SEGURA" ? " selected" : "")>Segura</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select name="filterType" class="form-select form-select-sm rounded-3"
                                onchange="this.form.submit()">
                            <option value="">Todos los tipos</option>
                            <option value="Texto"@(Model.FilterType == "Texto" ? " selected" : "")>Texto</option>
                            <option value="URL"@(Model.FilterType == "URL" ? " selected" : "")>URL</option>
                            <option value="Imagen"@(Model.FilterType == "Imagen" ? " selected" : "")>Imagen</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select name="filterDate" class="form-select form-select-sm rounded-3"
                                onchange="this.form.submit()">
                            <option value="">Cualquier fecha</option>
                            <option value="today"@(Model.FilterDate == "today" ? " selected" : "")>Hoy</option>
                            <option value="week"@(Model.FilterDate == "week" ? " selected" : "")>⁄ltima semana</option>
                            <option value="month"@(Model.FilterDate == "month" ? " selected" : "")>⁄ltimo mes</option>
                        </select>
                    </div>
                </div>

                @* Limpiar todos los filtros *@
                @if (Model.HasActiveFilters)
                {
                    <div class="mt-2">
                        <a asp-action="Index" class="text-muted small text-decoration-none">
                            <i class="bi bi-x-circle me-1"></i> Limpiar todos los filtros
                        </a>
                    </div>
                }

            </form>
        </div>
    </div>

    @* ‚îÄ‚îÄ Tabla de resultados ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ *@
    @if (!Model.Analyses.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <h5 class="fw-semibold mt-3 mb-1">
                    @if (Model.HasActiveFilters)
                    {
                        <span>Sin resultados para tu b√∫squeda</span>
                    }
                    else
                    {
                        <span>A√∫n no tienes an√°lisis</span>
                    }
                </h5>
                <p class="text-muted small mb-3">
                    @if (Model.HasActiveFilters)
                    {
                        <span>Intenta con otros t√©rminos o limpia los filtros.</span>
                    }
                    else
                    {
                        <span>Analiza un texto, URL o imagen para empezar.</span>
                    }
                </p>
                @if (Model.HasActiveFilters)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-3">
                        <i class="bi bi-x-circle me-1"></i> Limpiar filtros
                    </a>
                }
                else
                {
                    <a asp-controller="Text" asp-action="Index"
                       class="btn btn-primary btn-sm rounded-3">
                        <i class="bi bi-plus-circle me-1"></i> Nuevo an√°lisis
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Tipo</th>
                            <th>Contenido</th>
                            <th>Veredicto</th>
                            <th>Riesgo</th>
                            <th>Fecha</th>
                            <th class="pe-4"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Analyses)
                        {
                            string badgeClass = item.Verdict switch
                            {
                                "ESTAFA"     => "danger",
                                "SOSPECHOSA" => "warning",
                                "SEGURA"     => "success",
                                _            => "secondary"
                            };
                            string typeIcon = item.AnalysisType?.TypeName switch
                            {
                                "URL"    => "bi-link-45deg",
                                "Imagen" => "bi-file-image",
                                _        => "bi-chat-text"
                            };

                            <tr>
                                <td class="ps-4 text-muted small">#@item.AnalysisId</td>
                                <td>
                                    <i class="bi @typeIcon text-primary me-1"></i>
                                    <span class="small">@(item.AnalysisType?.TypeName ?? "Texto")</span>
                                </td>
                                <td style="max-width: 280px;">
                                    <span class="small text-truncate d-block"
                                          style="max-width: 280px;"
                                          title="@item.InputContent">
                                        @(item.InputContent?.Length > 80
                                            ? item.InputContent[..80] + "‚Ä¶"
                                            : item.InputContent)
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-@badgeClass rounded-pill">
                                        @item.Verdict
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress rounded-pill" style="width: 60px; height: 8px;">
                                            <div class="progress-bar bg-@badgeClass"
                                                 style="width: @item.RiskScore%"></div>
                                        </div>
                                        <span class="small text-muted">@item.RiskScore</span>
                                    </div>
                                </td>
                                <td class="small text-muted">
                                    @item.CreatedAt.ToString("dd/MM/yy HH:mm")
                                </td>
                                <td class="pe-4">
                                    <a asp-action="Detail"
                                       asp-route-id="@item.AnalysisId"
                                       class="btn btn-outline-primary btn-sm rounded-3">
                                        <i class="bi bi-eye me-1"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ‚îÄ‚îÄ Paginaci√≥n ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4 d-flex justify-content-center">
                <ul class="pagination pagination-sm">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link rounded-start-3"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-filterVerdict="@Model.FilterVerdict"
                           asp-route-filterType="@Model.FilterType"
                           asp-route-filterDate="@Model.FilterDate"
                           asp-route-search="@Model.Search">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-filterVerdict="@Model.FilterVerdict"
                               asp-route-filterType="@Model.FilterType"
                               asp-route-filterDate="@Model.FilterDate"
                               asp-route-search="@Model.Search">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link rounded-end-3"
                           asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-filterVerdict="@Model.FilterVerdict"
                           asp-route-filterType="@Model.FilterType"
                           asp-route-filterDate="@Model.FilterDate"
                           asp-route-search="@Model.Search">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }

</div>



